<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileConvert.ViewModels"
        xmlns:models="using:FileConvert.Models"
        xmlns:local="using:FileConvert.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="980" d:DesignHeight="680"
        Width="980" Height="680"
        MinWidth="900" MinHeight="620"
        x:Class="FileConvert.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/TypeConvert_Logo.ico"
        Title="FileConvert"
        CanResize="True"
        Background="#111111"
        KeyDown="OnWindowKeyDown">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>

        <!-- ═══ HEADER / ICON BUTTONS ═══ -->
        <Style Selector="Button.iconBtn">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"         Value="36"/>
            <Setter Property="Height"        Value="36"/>
            <Setter Property="CornerRadius"  Value="8"/>
            <Setter Property="Padding"       Value="0"/>
            <Setter Property="Cursor"        Value="Hand"/>
        </Style>
        <Style Selector="Button.iconBtn /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.iconBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a2a2a"/>
        </Style>

        <!-- ═══ TAB BUTTONS ═══ -->
        <Style Selector="Button.tabBtn">
            <Setter Property="Background"      Value="#252525"/>
            <Setter Property="Foreground"      Value="#999999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Cursor"                       Value="Hand"/>
            <Setter Property="FontFamily"               Value="{StaticResource NunitoFont}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>
        <Style Selector="Button.tabBtn /template/ ContentPresenter">
            <Setter Property="Background" Value="#252525"/>
        </Style>
        <Style Selector="Button.tabBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#333333"/>
        </Style>
        <Style Selector="Button.tabBtn.tabActive">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.tabBtn.tabActive /template/ ContentPresenter">
            <Setter Property="Background" Value="#0063b1"/>
        </Style>
        <Style Selector="Button.tabBtn.tabActive:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0078d4"/>
        </Style>
        <Style Selector="Button.tabBtn:disabled">
            <Setter Property="Opacity" Value="0.3"/>
        </Style>

        <!-- ═══ BATCH TOGGLE BUTTON ═══ -->
        <Style Selector="Button.batchToggle">
            <Setter Property="Background"      Value="#1e1e1e"/>
            <Setter Property="Foreground"      Value="#888888"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#333333"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="CornerRadius"    Value="14"/>
            <Setter Property="Cursor"                       Value="Hand"/>
            <Setter Property="FontFamily"               Value="{StaticResource NunitoFont}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>
        <Style Selector="Button.batchToggle /template/ ContentPresenter">
            <Setter Property="Background" Value="#1e1e1e"/>
        </Style>
        <Style Selector="Button.batchToggle.batchActive">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#0078d4"/>
        </Style>
        <Style Selector="Button.batchToggle.batchActive /template/ ContentPresenter">
            <Setter Property="Background" Value="#0d2a4a"/>
        </Style>

        <!-- ═══ FORMAT CHIP BUTTONS ═══ -->
        <Style Selector="Button.fmtChip">
            <Setter Property="Background"      Value="#222222"/>
            <Setter Property="Foreground"      Value="#aaaaaa"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#383838"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="11,0"/>
            <Setter Property="CornerRadius"    Value="14"/>
            <Setter Property="Margin"          Value="2,2"/>
            <Setter Property="Cursor"                       Value="Hand"/>
            <Setter Property="FontFamily"               Value="{StaticResource NunitoFont}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>
        <Style Selector="Button.fmtChip /template/ ContentPresenter">
            <Setter Property="Background" Value="#222222"/>
        </Style>
        <Style Selector="Button.fmtChip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2e2e2e"/>
        </Style>
        <Style Selector="Button.fmtChip.fmtActive">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#0078d4"/>
        </Style>
        <Style Selector="Button.fmtChip.fmtActive /template/ ContentPresenter">
            <Setter Property="Background" Value="#0063b1"/>
        </Style>
        <Style Selector="Button.fmtChip.fmtActive:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0078d4"/>
        </Style>

        <!-- ═══ METADATA ROWS ═══ -->
        <Style Selector="TextBlock.metaKey">
            <Setter Property="FontSize"     Value="9"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="#505050"/>
            <Setter Property="LetterSpacing" Value="1.2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.metaVal">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="Foreground"        Value="#d0d0d0"/>
            <Setter Property="FontFamily"        Value="{StaticResource NunitoFont}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping"      Value="Wrap"/>
        </Style>
        <Style Selector="TextBlock.sectionHdr">
            <Setter Property="FontSize"      Value="9"/>
            <Setter Property="FontWeight"    Value="Bold"/>
            <Setter Property="Foreground"    Value="#444444"/>
            <Setter Property="LetterSpacing" Value="2"/>
        </Style>

        <!-- ═══ CARD BORDER ═══ -->
        <Style Selector="Border.card">
            <Setter Property="Background"     Value="#1e1e1e"/>
            <Setter Property="CornerRadius"   Value="8"/>
            <Setter Property="Padding"        Value="12,10"/>
        </Style>

        <!-- ═══ BATCH LIST ITEM ═══ -->
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="8,4"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#252525"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1e1e1e"/>
        </Style>

    </Window.Styles>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!--  ROOT GRID: Header | Content | Footer                           -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <Grid RowDefinitions="50, *, 58">

        <!-- ╔══════════════════════════════════════════════════════╗ -->
        <!-- ║  ROW 0 — Header                                      ║ -->
        <!-- ╚══════════════════════════════════════════════════════╝ -->
        <Grid Grid.Row="0" Background="#0a0a0a"
              ColumnDefinitions="Auto, Auto, Auto, *, Auto, Auto, Auto">

            <!-- Logo -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="16,0,20,0">
                <Image Source="/Assets/TypeConvert_Logo.ico"
                       Width="22" Height="22" Margin="0,0,9,0"/>
                <TextBlock Text="FileConvert" FontSize="15" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"
                           FontFamily="{StaticResource NunitoFont}"/>
            </StackPanel>

            <!-- Batch mode toggle -->
            <Button Grid.Column="1"
                    x:Name="BatchModeToggle"
                    Content="⊞  Batch Mode"
                    Classes="batchToggle"
                    Click="OnBatchModeToggleClicked"
                    VerticalAlignment="Center"/>

            <!-- History toggle -->
            <Button Grid.Column="2"
                    x:Name="HistoryToggle"
                    Content="⟳  History"
                    Classes="batchToggle"
                    Click="OnHistoryToggleClicked"
                    VerticalAlignment="Center"
                    Margin="6,0,0,0"/>

            <!-- Spacer -->
            <Border Grid.Column="3"/>

            <!-- Version label -->
            <TextBlock Grid.Column="4" Text="v0.3b"
                       Foreground="#333333" FontSize="10"
                       VerticalAlignment="Center" Margin="0,0,12,0"
                       FontFamily="{StaticResource NunitoFont}"/>

            <!-- Settings -->
            <Button Grid.Column="5"
                    Command="{Binding OpenSettingsSelectCommand}"
                    Classes="iconBtn"
                    ToolTip.Tip="Settings"
                    Margin="0,0,4,0">
                <Image Source="/Assets/SettingsIcon.png" Width="17" Height="17"/>
            </Button>

            <!-- GitHub -->
            <Button Grid.Column="6"
                    Click="OnGithubButtonClicked"
                    Classes="iconBtn"
                    ToolTip.Tip="GitHub"
                    Margin="0,0,10,0">
                <Image Source="/Assets/Github.png" Width="17" Height="17"/>
            </Button>
        </Grid>

        <!-- ╔══════════════════════════════════════════════════════╗ -->
        <!-- ║  ROW 1 — Main content                                ║ -->
        <!-- ╚══════════════════════════════════════════════════════╝ -->
        <Grid Grid.Row="1" ColumnDefinitions="252, *">

            <!-- ┌────────────────────────────────┐ -->
            <!-- │  LEFT PANEL                    │ -->
            <!-- └────────────────────────────────┘ -->
            <Grid Grid.Column="0" Background="#0f0f0f">

                <!-- ── SINGLE FILE INFO (default visible) ── -->
                <Grid x:Name="SingleFilePanel" RowDefinitions="Auto, Auto, *">

                    <!-- Preview -->
                    <Border Grid.Row="0"
                            Background="#1a1a1a"
                            BorderBrush="#282828" BorderThickness="1"
                            Margin="10,10,10,8" CornerRadius="8"
                            Height="160" ClipToBounds="True"
                            DragDrop.AllowDrop="True">
                        <Panel>
                            <Image x:Name="SelectedImage"
                                   Stretch="Uniform"
                                   PointerPressed="OpenEnlargedImage"/>
                            <!-- Audio / no-preview placeholder -->
                            <TextBlock x:Name="PreviewPlaceholder"
                                       Text="♪"
                                       FontSize="42"
                                       Foreground="#252525"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource NunitoFont}"
                                       IsVisible="False"/>
                            <!-- Video preview badge -->
                            <Border x:Name="VideoPreviewBadge"
                                    IsVisible="False"
                                    Background="#bb000000"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                    Margin="6" Padding="5,2">
                                <TextBlock Text="VIDEO PREVIEW"
                                           Foreground="#999999" FontSize="8"
                                           FontWeight="Bold" LetterSpacing="1"
                                           FontFamily="{StaticResource NunitoFont}"/>
                            </Border>
                            <!-- Drag hint overlay, hidden until drag enters -->
                            <Border x:Name="DragHintOverlay"
                                    IsVisible="False"
                                    Background="#cc0078d4"
                                    CornerRadius="8">
                                <TextBlock Text="Drop file here"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="White" FontSize="13"
                                           FontWeight="Bold"
                                           FontFamily="{StaticResource NunitoFont}"/>
                            </Border>
                        </Panel>
                    </Border>

                    <!-- File-load progress bar (thin, indeterminate) -->
                    <ProgressBar Grid.Row="1"
                                 x:Name="PreviewLoadingBar"
                                 IsIndeterminate="True"
                                 IsVisible="False"
                                 Height="2" Margin="10,2,10,0"
                                 Foreground="#0078d4" Background="Transparent"/>

                    <!-- Scrollable metadata -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="10,0,10,10">

                            <!-- ── FILE INFO section ── -->
                            <TextBlock Text="FILE INFO" Classes="sectionHdr" Margin="2,4,0,6"/>

                            <Grid ColumnDefinitions="76, *" Margin="2,0,2,3">
                                <TextBlock Grid.Column="0" Text="NAME"  Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaFileName" Classes="metaVal" Text="—"/>
                            </Grid>
                            <Grid ColumnDefinitions="76, *" Margin="2,0,2,3">
                                <TextBlock Grid.Column="0" Text="TYPE"  Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaFileType" Classes="metaVal" Text="—"/>
                            </Grid>
                            <Grid ColumnDefinitions="76, *" Margin="2,0,2,8">
                                <TextBlock Grid.Column="0" Text="SIZE"  Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaFileSize" Classes="metaVal" Text="—"/>
                            </Grid>

                            <!-- ── MEDIA INFO section (shown when file loaded) ── -->
                            <TextBlock x:Name="MediaInfoHeader"
                                       Text="MEDIA INFO" Classes="sectionHdr"
                                       Margin="2,0,0,6" IsVisible="False"/>

                            <!-- Resolution (image + video) -->
                            <Grid x:Name="RowResolution"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="RESOLUTION" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaResolution" Classes="metaVal"/>
                            </Grid>

                            <!-- Color space (image) -->
                            <Grid x:Name="RowColorSpace"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="COLOR" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaColorSpace" Classes="metaVal"/>
                            </Grid>

                            <!-- Bit depth (image) -->
                            <Grid x:Name="RowBitDepth"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="BIT DEPTH" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaBitDepth" Classes="metaVal"/>
                            </Grid>

                            <!-- Duration (audio + video) -->
                            <Grid x:Name="RowDuration"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="DURATION" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaDuration" Classes="metaVal"/>
                            </Grid>

                            <!-- FPS (video) -->
                            <Grid x:Name="RowFPS"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="FPS" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaFPS" Classes="metaVal"/>
                            </Grid>

                            <!-- Bitrate (audio + video) -->
                            <Grid x:Name="RowBitrate"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="BITRATE" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaBitrate" Classes="metaVal"/>
                            </Grid>

                            <!-- Sample rate (audio) -->
                            <Grid x:Name="RowSampleRate"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="SAMPLE RATE" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaSampleRate" Classes="metaVal"/>
                            </Grid>

                            <!-- Channels (audio) -->
                            <Grid x:Name="RowChannels"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="CHANNELS" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaChannels" Classes="metaVal"/>
                            </Grid>

                            <!-- Video codec (video) -->
                            <Grid x:Name="RowVCodec"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="V.CODEC" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaVCodec" Classes="metaVal"/>
                            </Grid>

                            <!-- Audio codec (audio + video) -->
                            <Grid x:Name="RowACodec"
                                  ColumnDefinitions="76, *" Margin="2,0,2,3" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="A.CODEC" Classes="metaKey"/>
                                <TextBlock Grid.Column="1" x:Name="MetaACodec" Classes="metaVal"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── HISTORY PANEL (hidden by default) ── -->
                <Grid x:Name="HistoryPanel"
                      IsVisible="False"
                      RowDefinitions="Auto, *">

                    <Grid Grid.Row="0" Margin="10,10,10,6"
                          ColumnDefinitions="*, Auto">
                        <TextBlock Grid.Column="0"
                                   Text="HISTORY"
                                   Classes="sectionHdr"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="Clear"
                                Classes="tabBtn"
                                Height="26" Padding="8,0" FontSize="11"
                                Click="OnHistoryClearClicked"
                                ToolTip.Tip="Clear conversion history"/>
                    </Grid>

                    <ListBox Grid.Row="1"
                             Background="#0f0f0f"
                             BorderThickness="0"
                             ItemsSource="{Binding ConversionHistory}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ConversionHistoryEntry">
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding DisplayLine}"
                                               Foreground="#bbbbbb" FontSize="11"
                                               FontFamily="{StaticResource NunitoFont}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding SizeLine}"
                                                   Foreground="#555555" FontSize="9"
                                                   FontFamily="{StaticResource NunitoFont}"/>
                                        <TextBlock Text="{Binding TimeLine}"
                                                   Foreground="#3a3a3a" FontSize="9"
                                                   FontFamily="{StaticResource NunitoFont}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- ── BATCH QUEUE PANEL (hidden by default) ── -->
                <Grid x:Name="BatchPanel"
                      IsVisible="False"
                      RowDefinitions="Auto, *, Auto">

                    <!-- Batch header toolbar -->
                    <Grid Grid.Row="0" Margin="10,10,10,6"
                          ColumnDefinitions="*, Auto, Auto, Auto">
                        <TextBlock Grid.Column="0"
                                   x:Name="BatchHeaderLabel"
                                   Text="BATCH QUEUE"
                                   Classes="sectionHdr"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="Clear Done"
                                Classes="tabBtn"
                                Height="26" Padding="8,0" FontSize="11"
                                Click="OnBatchClearDoneClicked"
                                Margin="0,0,4,0"
                                ToolTip.Tip="Remove completed and errored items"/>
                        <Button Grid.Column="2"
                                Content="+ Add"
                                Classes="tabBtn"
                                Height="26" Padding="8,0" FontSize="11"
                                Click="OnBatchAddFilesClicked"
                                Margin="0,0,4,0"/>
                        <Button Grid.Column="3"
                                Content="Clear All"
                                Classes="tabBtn"
                                Height="26" Padding="8,0" FontSize="11"
                                Click="OnBatchClearClicked"/>
                    </Grid>

                    <!-- File queue list -->
                    <ListBox Grid.Row="1"
                             x:Name="BatchQueueList"
                             Background="#0f0f0f"
                             BorderThickness="0"
                             ItemsSource="{Binding BatchQueue}"
                             KeyDown="OnBatchListKeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:BatchFileItem">
                                <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,1">
                                    <!-- Status dot -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Status, Converter={x:Static local:MainWindow.StatusToSymbol}}"
                                               Foreground="{Binding Status, Converter={x:Static local:MainWindow.StatusToColor}}"
                                               FontSize="12" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <!-- Filename -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding FileName}"
                                               Foreground="#bbbbbb" FontSize="11"
                                               FontFamily="{StaticResource NunitoFont}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <!-- Status text -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding StatusText}"
                                               Foreground="{Binding Status, Converter={x:Static local:MainWindow.StatusToColor}}"
                                               FontSize="9" FontWeight="Bold"
                                               FontFamily="{StaticResource NunitoFont}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                    <!-- Remove button -->
                                    <Button Grid.Column="3"
                                            Content="✕"
                                            Click="OnBatchItemRemoveClicked"
                                            Background="Transparent" Foreground="#444444"
                                            BorderThickness="0" Width="22" Height="22"
                                            Padding="0" FontSize="10" Cursor="Hand"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            ToolTip.Tip="Remove (Delete)"
                                            FontFamily="{StaticResource NunitoFont}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Progress row -->
                    <StackPanel Grid.Row="2" Margin="10,6,10,10">
                        <TextBlock x:Name="BatchProgressText"
                                   Text="0 files queued"
                                   Foreground="#555555" FontSize="10"
                                   FontFamily="{StaticResource NunitoFont}"
                                   Margin="0,0,0,4"/>
                        <ProgressBar x:Name="BatchProgressBar"
                                     Minimum="0" Maximum="100" Value="0"
                                     Height="3" IsVisible="False"
                                     Foreground="#0078d4" Background="#222222"/>
                    </StackPanel>
                </Grid>

            </Grid>

            <!-- ┌────────────────────────────────┐ -->
            <!-- │  RIGHT PANEL                   │ -->
            <!-- └────────────────────────────────┘ -->
            <Grid Grid.Column="1" Background="#161616"
                  RowDefinitions="Auto, Auto, *">

                <!-- Input file row (with drag & drop, events attached in code-behind) -->
                <Border Grid.Row="0"
                        x:Name="InputFileBorder"
                        Classes="card"
                        Margin="12,10,12,6"
                        DragDrop.AllowDrop="True">
                    <Grid ColumnDefinitions="*, Auto, Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="INPUT FILE" Classes="sectionHdr" Margin="0,0,0,5"/>
                            <TextBlock x:Name="SelectedFileNameDisplay"
                                       Text="No file selected — click Browse or drop a file here"
                                       Foreground="#4a4a4a" FontSize="11"
                                       FontFamily="{StaticResource NunitoFont}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                x:Name="ClearFileButton"
                                Content="✕"
                                Click="OnClearFileClicked"
                                IsVisible="False"
                                Classes="tabBtn"
                                Height="30" Width="30" Padding="0"
                                FontSize="12" Margin="10,0,0,0"
                                ToolTip.Tip="Clear file"/>
                        <Button Grid.Column="2"
                                Content="Browse…"
                                Click="OnSelectFileButtonClicked"
                                Classes="tabBtn"
                                Height="30" Padding="14,0"
                                FontSize="12" Margin="6,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Output format section -->
                <Border Grid.Row="1"
                        Classes="card"
                        Margin="12,0,12,6">
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                            <TextBlock Grid.Column="0" Text="OUTPUT FORMAT" Classes="sectionHdr" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="ConversionArrowLabel"
                                       Foreground="#444444" FontSize="10" FontWeight="Bold"
                                       FontFamily="{StaticResource NunitoFont}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Category tab buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,10">
                            <Button x:Name="TabImageButton"
                                    Content="Image"
                                    Classes="tabBtn tabActive"
                                    Click="OnTabButtonClicked" Tag="0"/>
                            <Button x:Name="TabAudioButton"
                                    Content="Audio"
                                    Classes="tabBtn"
                                    Click="OnTabButtonClicked" Tag="1"/>
                            <Button x:Name="TabVideoButton"
                                    Content="Video"
                                    Classes="tabBtn"
                                    Click="OnTabButtonClicked" Tag="2"/>
                        </StackPanel>

                        <!-- IMAGE chips -->
                        <WrapPanel x:Name="ImageFormatPanel" Orientation="Horizontal">
                            <Button Classes="fmtChip fmtActive" Content="PNG"  Tag="PNG"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="JPG"  Tag="JPG"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="WEBP" Tag="WEBP" Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="GIF"  Tag="GIF"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="BMP"  Tag="BMP"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="TIFF" Tag="TIFF" Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="ICO"  Tag="ICO"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="AVIF" Tag="AVIF" Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="HEIC" Tag="HEIC" Click="OnFormatChipClicked"/>
                        </WrapPanel>

                        <!-- AUDIO chips -->
                        <WrapPanel x:Name="AudioFormatPanel" Orientation="Horizontal" IsVisible="False">
                            <Button Classes="fmtChip fmtActive" Content="MP3"  Tag="MP3"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="WAV"  Tag="WAV"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="FLAC" Tag="FLAC" Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="OGG"  Tag="OGG"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="AAC"  Tag="AAC"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="M4A"  Tag="M4A"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="OPUS" Tag="OPUS" Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="AIFF" Tag="AIFF" Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="WMA"  Tag="WMA"  Click="OnFormatChipClicked"/>
                        </WrapPanel>

                        <!-- VIDEO chips -->
                        <WrapPanel x:Name="VideoFormatPanel" Orientation="Horizontal" IsVisible="False">
                            <Button Classes="fmtChip fmtActive" Content="MP4"  Tag="MP4"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="MOV"  Tag="MOV"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="AVI"  Tag="AVI"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="MKV"  Tag="MKV"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="WEBM" Tag="WEBM" Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="FLV"  Tag="FLV"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="WMV"  Tag="WMV"  Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="TS"   Tag="TS"   Click="OnFormatChipClicked"/>
                            <Button Classes="fmtChip"           Content="GIF"  Tag="GIF"  Click="OnFormatChipClicked"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Options section -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <Border Classes="card" Margin="12,0,12,10" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="OPTIONS" Classes="sectionHdr" Margin="0,0,0,10"/>

                            <!-- Quality -->
                            <Grid ColumnDefinitions="70, *, Auto" Margin="0,0,0,10">
                                <TextBlock Grid.Column="0" Text="Quality"
                                           Foreground="#777777" FontSize="11"
                                           FontWeight="SemiBold" VerticalAlignment="Center"
                                           FontFamily="{StaticResource NunitoFont}"/>
                                <Slider Grid.Column="1"
                                        x:Name="QualitySlider"
                                        Minimum="0" Maximum="100" Value="80"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        Margin="8,0"/>
                                <Border Grid.Column="2"
                                        Background="#252525" CornerRadius="4"
                                        Padding="6,2" Width="38">
                                    <TextBlock Text="{Binding #QualitySlider.Value, StringFormat={}{0:0}}"
                                               Foreground="White" FontSize="11"
                                               FontWeight="Bold" TextAlignment="Center"
                                               FontFamily="{StaticResource NunitoFont}"/>
                                </Border>
                            </Grid>

                            <!-- Resolution -->
                            <StackPanel x:Name="ResolutionPanel">
                                <Grid ColumnDefinitions="70, *, Auto, Auto, *, Auto" Margin="0,0,0,0">
                                    <TextBlock Grid.Column="0" Text="Resolution"
                                               Foreground="#777777" FontSize="11"
                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                               FontFamily="{StaticResource NunitoFont}"/>
                                    <TextBox Grid.Column="1"
                                             x:Name="ResolutionWidthInput"
                                             Watermark="W" Height="30"
                                             Background="#252525" BorderBrush="#383838"
                                             TextChanged="OnResolutionInputTextChanged"/>
                                    <TextBlock Grid.Column="2"
                                               Text="×" Foreground="#444444"
                                               FontSize="14" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" Margin="6,0"/>
                                    <Button Grid.Column="3"
                                            x:Name="AspectRatioLockButton"
                                            Content="AR"
                                            Click="OnAspectRatioLockClicked"
                                            Background="#1e1e1e" Foreground="#555555"
                                            BorderBrush="#333333" BorderThickness="1"
                                            CornerRadius="4" Height="24" Padding="5,0"
                                            FontSize="9" FontWeight="Bold" Margin="0,0,6,0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontFamily="{StaticResource NunitoFont}"
                                            ToolTip.Tip="Lock aspect ratio"/>
                                    <TextBox Grid.Column="4"
                                             x:Name="ResolutionHeightInput"
                                             Watermark="H" Height="30"
                                             Background="#252525" BorderBrush="#383838"
                                             TextChanged="OnResolutionInputTextChanged"/>
                                    <TextBlock Grid.Column="5"
                                               x:Name="OriginalResolutionHint"
                                               Foreground="#3a3a3a" FontSize="9"
                                               FontFamily="{StaticResource NunitoFont}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0" TextWrapping="Wrap"
                                               MaxWidth="60"/>
                                </Grid>
                            </StackPanel>

                            <!-- Trim (visible for audio/video inputs) -->
                            <StackPanel x:Name="TrimPanel" IsVisible="False" Margin="0,10,0,0">
                                <Grid ColumnDefinitions="70, *, Auto, *, Auto" Margin="0,0,0,0">
                                    <TextBlock Grid.Column="0" Text="Trim"
                                               Foreground="#777777" FontSize="11"
                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                               FontFamily="{StaticResource NunitoFont}"/>
                                    <TextBox Grid.Column="1"
                                             x:Name="TrimStartInput"
                                             Watermark="start" Height="30"
                                             Background="#252525" BorderBrush="#383838"
                                             ToolTip.Tip="Start time (hh:mm:ss or seconds)"
                                             TextChanged="OnTrimInputChanged"/>
                                    <TextBlock Grid.Column="2"
                                               Text="→" Foreground="#444444"
                                               FontSize="12" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" Margin="6,0"/>
                                    <TextBox Grid.Column="3"
                                             x:Name="TrimEndInput"
                                             Watermark="end" Height="30"
                                             Background="#252525" BorderBrush="#383838"
                                             ToolTip.Tip="End time (hh:mm:ss or seconds)"
                                             TextChanged="OnTrimInputChanged"/>
                                    <TextBlock Grid.Column="4"
                                               Text="hh:mm:ss" Foreground="#2a2a2a"
                                               FontSize="9" VerticalAlignment="Center"
                                               Margin="6,0,0,0"
                                               FontFamily="{StaticResource NunitoFont}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Audio → Video background options (audio input + video output tab) -->
                            <StackPanel x:Name="AudioToVideoPanel" IsVisible="False" Margin="0,10,0,0">
                                <TextBlock Text="BACKGROUND" Classes="sectionHdr" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="ATVColorChip"
                                            Content="Solid Color"
                                            Classes="fmtChip fmtActive"
                                            Tag="color" Height="26" Padding="10,0"
                                            Click="OnATVModeClicked"/>
                                    <Button x:Name="ATVImageChip"
                                            Content="Use Image"
                                            Classes="fmtChip"
                                            Tag="image" Height="26" Padding="10,0"
                                            Click="OnATVModeClicked"/>
                                </StackPanel>
                                <!-- Solid color row -->
                                <Grid x:Name="ATVColorRow" ColumnDefinitions="Auto, Auto, *">
                                    <Border Grid.Column="0"
                                            x:Name="ATVColorPreview"
                                            Width="28" Height="28" CornerRadius="4"
                                            Background="#1a1a1a"
                                            BorderBrush="#383838" BorderThickness="1"
                                            Margin="0,0,6,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="#" Foreground="#555555" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,3,0"
                                               FontFamily="{StaticResource NunitoFont}"/>
                                    <TextBox Grid.Column="2"
                                             x:Name="ATVColorBox"
                                             Text="1a1a1a" Watermark="rrggbb"
                                             Background="#252525" BorderBrush="#383838"
                                             Height="28"
                                             TextChanged="OnATVColorChanged"/>
                                </Grid>
                                <!-- Image path row -->
                                <Grid x:Name="ATVImageRow"
                                      ColumnDefinitions="*, Auto"
                                      IsVisible="False" Margin="0,0,0,0">
                                    <TextBox Grid.Column="0"
                                             x:Name="ATVImagePathBox"
                                             Watermark="Background image path…"
                                             IsReadOnly="True"
                                             Background="#252525" BorderBrush="#383838"
                                             Height="28"/>
                                    <Button Grid.Column="1"
                                            Content="Browse…"
                                            Classes="tabBtn"
                                            Height="28" Padding="10,0"
                                            Margin="4,0,0,0"
                                            Click="OnATVImageBrowseClicked"/>
                                </Grid>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </ScrollViewer>

            </Grid>
        </Grid>

        <!-- ╔══════════════════════════════════════════════════════╗ -->
        <!-- ║  ROW 2 — Footer                                      ║ -->
        <!-- ╚══════════════════════════════════════════════════════╝ -->
        <Grid Grid.Row="2" Background="#0a0a0a"
              ColumnDefinitions="Auto, *, Auto, Auto, Auto">

            <!-- Open output folder + Copy path -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0">
                <Button x:Name="OutputButton"
                        Content="Open Output Folder"
                        IsEnabled="False"
                        Command="{Binding OpenLastOutputFolderCommand}"
                        Classes="tabBtn"
                        Height="36" Padding="14,0"
                        FontSize="11"/>
                <Button x:Name="CopyPathButton"
                        Content="Copy Path"
                        IsEnabled="False"
                        IsVisible="False"
                        Click="OnCopyPathClicked"
                        Classes="tabBtn"
                        Height="36" Padding="12,0"
                        FontSize="11" Margin="6,0,0,0"
                        ToolTip.Tip="Copy output file path to clipboard"/>
            </StackPanel>

            <!-- Status / error text + progress bar -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock x:Name="OutputPreviewText"
                           Foreground="#3a3a3a" FontSize="10"
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource NunitoFont}"
                           Margin="0,0,0,2"/>
                <TextBlock x:Name="ErrorText"
                           Foreground="#d04040" FontSize="11"
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource NunitoFont}"/>
                <TextBlock x:Name="ConversionPercentText"
                           Foreground="#777777" FontSize="10"
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource NunitoFont}"
                           IsVisible="False"
                           Margin="0,4,0,1"/>
                <ProgressBar x:Name="ConversionProgress"
                             IsIndeterminate="True"
                             IsVisible="False"
                             Height="2" Width="200"
                             Margin="0,0,0,0"
                             Foreground="#0078d4" Background="Transparent"/>
            </StackPanel>

            <!-- Cancel button (visible during conversion) -->
            <Button Grid.Column="2"
                    x:Name="CancelButton"
                    Content="Cancel"
                    IsVisible="False"
                    Click="OnCancelClicked"
                    Background="#2a1212" Foreground="#ff6b6b"
                    BorderBrush="#5a2222" BorderThickness="1"
                    CornerRadius="6" Height="36" Padding="20,0"
                    FontSize="13" FontWeight="Bold"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Margin="0,0,6,0"
                    FontFamily="{StaticResource NunitoFont}"
                    ToolTip.Tip="Cancel conversion"/>

            <!-- Convert button (single) -->
            <Button Grid.Column="3"
                    x:Name="GenerateButton"
                    Content="Convert"
                    IsEnabled="False"
                    IsVisible="True"
                    Click="OnGenerateButtonClicked"
                    Background="#0063b1" Foreground="White"
                    BorderThickness="0" CornerRadius="6"
                    Height="36" Padding="26,0"
                    FontSize="13" FontWeight="Bold"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Margin="0,0,6,0"
                    FontFamily="{StaticResource NunitoFont}"/>

            <!-- Convert All button (batch) -->
            <Button Grid.Column="4"
                    x:Name="BatchConvertButton"
                    Content="Convert All"
                    IsEnabled="False"
                    IsVisible="False"
                    Click="OnBatchConvertClicked"
                    Background="#0063b1" Foreground="White"
                    BorderThickness="0" CornerRadius="6"
                    Height="36" Padding="26,0"
                    FontSize="13" FontWeight="Bold"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Margin="0,0,12,0"
                    FontFamily="{StaticResource NunitoFont}"/>
        </Grid>

    </Grid>
</Window>
